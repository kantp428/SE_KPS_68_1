# ใช้ Node.js 22 ตามคำแนะนำของ Prisma 7
FROM node:22-slim AS runner

# 1. ติดตั้ง openssl (จำเป็นมากสำหรับ PostgreSQL/Neon บน Linux)
RUN apt-get update -y && apt-get install -y openssl

WORKDIR /app

# 2. คัดลอกไฟล์ตั้งค่า Package
COPY package*.json ./

# 3. ติดตั้ง Dependencies (รวมถึง pg และ @prisma/adapter-pg)
RUN npm install

# 4. คัดลอกโฟลเดอร์ prisma และโค้ดทั้งหมด
COPY prisma ./prisma/
COPY . .

# 5. Generate Prisma Client 
# ขั้นตอนนี้จะใช้ prisma.config.ts ของคุณโดยอัตโนมัติ
RUN npx prisma generate

# 6. Build Next.js โปรเจกต์
RUN npm run build

# 7. สั่งรันแอป
CMD ["sh", "-c", "npx prisma db push && npm start"]