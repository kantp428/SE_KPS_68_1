generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model account {
  id            Int               @id @default(autoincrement())
  username      String            @unique @db.VarChar(50)
  email         String            @unique @db.VarChar(100)
  password_hash String
  account_role  account_role_enum
  patient       patient?
  staff         staff?
}

model appointment {
  id           Int                     @id @default(autoincrement())
  service_id   Int
  patient_id   Int
  doctor_id    Int?
  start_at     DateTime                @db.Timestamptz(6)
  end_at       DateTime                @db.Timestamptz(6)
  is_walked_in Boolean                 @default(false)
  status       appointment_status_enum @default(PENDING)
  staff        staff?                  @relation(fields: [doctor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_app_doctor")
  patient      patient                 @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_app_patient")
  service      service                 @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_app_service")
  treatment    treatment?
}

model health_profile {
  id         Int         @id @default(autoincrement())
  patient_id Int
  weight     Decimal     @db.Decimal(5, 2)
  height     Decimal     @db.Decimal(5, 2)
  bp         Int
  vitals     Json
  symptoms   String
  date_time  DateTime    @default(now()) @db.Timestamptz(6)
  patient    patient     @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_hp_patient")
  treatment  treatment[]
}

model invoice {
  id           Int                 @id @default(autoincrement())
  patient_id   Int
  total_amount Decimal             @default(0.00) @db.Decimal(12, 2)
  status       invoice_status_enum @default(UNPAID)
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  patient      patient             @relation(fields: [patient_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_patient")
  invoice_item invoice_item[]
}

model invoice_item {
  id          Int       @id @default(autoincrement())
  invoice_id  Int
  service_id  Int?
  medicine_id Int?
  quantity    Int       @default(1)
  unit_price  Decimal   @db.Decimal(10, 2)
  invoice     invoice   @relation(fields: [invoice_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_inv")
  medicine    medicine? @relation(fields: [medicine_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_medicine")
  service     service?  @relation(fields: [service_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_item_service")
}

model medicine {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(100)
  description  String
  price        Decimal        @db.Decimal(10, 2)
  invoice_item invoice_item[]
}

model patient {
  id              Int              @id @default(autoincrement())
  first_name      String           @db.VarChar(50)
  last_name       String           @db.VarChar(50)
  thai_id         String           @unique @db.VarChar(13)
  birthdate       DateTime         @db.Date
  gender          gender_enum
  phone_number    String           @db.VarChar(20)
  blood_group     blood_group_enum
  chronic_disease String?
  account_id      Int?             @unique
  appointment     appointment[]
  health_profile  health_profile[]
  invoice         invoice[]
  account         account?         @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_patient_account")
}

model room {
  id        Int              @id @default(autoincrement())
  name      String           @db.VarChar(50)
  status    room_status_enum @default(AVAILABLE)
  treatment treatment[]
}

model service {
  id              Int            @id @default(autoincrement())
  name            String         @db.VarChar(100)
  price           Decimal        @db.Decimal(10, 2)
  duration_minute Int
  appointment     appointment[]
  invoice_item    invoice_item[]
}

model staff {
  id            Int             @id @default(autoincrement())
  first_name    String          @db.VarChar(50)
  last_name     String          @db.VarChar(50)
  gender        gender_enum
  phone_number  String          @db.VarChar(20)
  staff_role    staff_role_enum
  account_id    Int             @unique
  appointment   appointment[]
  account       account         @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_staff_account")
  work_schedule work_schedule[]
}

model treatment {
  id                Int                   @id @default(autoincrement())
  health_profile_id Int
  appointment_id    Int                   @unique
  room_id           Int
  date_time         DateTime              @default(now()) @db.Timestamptz(6)
  treatment_status  treatment_status_enum
  appointment       appointment           @relation(fields: [appointment_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_treat_app")
  health_profile    health_profile        @relation(fields: [health_profile_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_treat_hp")
  room              room                  @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_treat_room")
}

model work_schedule {
  id        Int      @id @default(autoincrement())
  staff_id  Int
  date      DateTime @db.Date
  starttime DateTime @db.Time(6)
  endtime   DateTime @db.Time(6)
  is_active Boolean  @default(true)
  staff     staff    @relation(fields: [staff_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_schedule_staff")
}

enum account_role_enum {
  ADMIN
  STAFF
  PATIENT
}

enum appointment_status_enum {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum blood_group_enum {
  A
  B
  AB
  O
  A_POS  @map("A+")
  A_NEG  @map("A-")
  B_POS  @map("B+")
  B_NEG  @map("B-")
  AB_POS @map("AB+")
  AB_NEG @map("AB-")
  O_POS  @map("O+")
  O_NEG  @map("O-")
}

enum gender_enum {
  MALE
  FEMALE
  OTHER
}

enum invoice_status_enum {
  UNPAID
  PAID
  VOID
}

enum room_status_enum {
  AVAILABLE
  UNAVAILABLE
}

enum staff_role_enum {
  DOCTOR
  MED_ASSISTANT
}

enum treatment_status_enum {
  IN_PROGRESS
  COMPLETED
  FOLLOW_UP
}
